# Copy to .env and fill in values. Do not commit .env.

BASE_URL=https://parser-staging.boostkh.com
TENANT_TOKEN=sk_fc60b3f006ae79e61f55096f11fe7cd2

# App-level Bearer API key (Swagger: BearerAuth). Sent as `Authorization: Bearer <API_KEY>`.
# Typically an `sk_...` value issued by the platform.
API_KEY=sk_fc60b3f006ae79e61f55096f11fe7cd2

# Google Cloud IAP (Identity-Aware Proxy) access.
# IAP_CLIENT_ID is the OAuth 2.0 client ID of the IAP-protected backend (audience).
# GOOGLE_APPLICATION_CREDENTIALS points to a service account JSON file whose
# principal has roles/iap.httpsResourceAccessor on the backend.
IAP_CLIENT_ID=1019050071398-5460uegjhsidl7kadntmh4is7e0395kg.apps.googleusercontent.com
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/v_nel/Documents/verifyiq-api-regression/qa-api-tester-key.json

# Required: GCS-backed fixture for /parse happy path tests.
# The API fetches this server-side; the test runner does not need GCS credentials.
# GCS paths are environment-specific — pick one valid for the current BASE_URL.
PARSE_FIXTURE_FILE=gs://test-ai-docs-data-staging/Cashalo/BankStatement/BPI/3_2025-12-15_BPIsa eStatement-Oct 2025.pdf
PARSE_FIXTURE_FILE_TYPE=BankStatement
